<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.program.koditoolbox" version="1.0.0" name="Kodi Toolbox" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">System utility toolbox for Kodi</summary>
        <description lang="en">Dashboard, cleaner, log viewer, backup, and more</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="plugin.video.lordplayer" name="LordPlayer" provider-name="opencode" version="1.0.0">
    <requires>
        <import addon="script.module.requests" version="2.22.0"/>
        <import addon="script.module.routing" version="0.2.3"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="navigation.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <license>MIT</license>
        <summary lang="en">LordPlayer - Torrent streaming player</summary>
        <description lang="en">LordPlayer is a torrent streaming service with a rest API for Kodi playback.</description>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
        <reuselanguageinvoker>true</reuselanguageinvoker>
    </extension>
</addon>
<addon id="plugin.video.streamlord" name="StreamLord" version="1.0.0" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.cocoscrapers"/>
        <import addon="script.module.resolveurl"/>
        <import addon="inputstream.adaptive"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">StreamLord - Watch Movies &amp; TV Shows</summary>
        <description lang="en_GB">Browse and stream movies and TV shows from StreamLord.to</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
<addon id="plugin.video.xprime" version="1.0.1" name="XPrime" provider-name="opencode">
    <requires>
        <import addon="script.module.six"/>
        <import addon="script.module.kodi-six"/>
        <import addon="script.module.simplejson"/>
        <import addon="script.module.requests"/>
        <import addon="script.module.resolveurl"/>
        <import addon="script.module.cocoscrapers"/>
        <import addon="script.trakt" optional="true"/>
        <import addon="plugin.video.youtube" optional="true"/>
        <import addon="inputstream.adaptive"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">XPrime - Watch Movies &amp; TV Shows</summary>
        <description lang="en">Browse and stream movies and TV shows powered by XPrime</description>
        <language>en</language>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart_xp.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="skin.marmalade" version="1.0.0" name="Marmalade Build" provider-name="opencode">
	<requires>
		<import addon="xbmc.gui" version="5.17.0" />
		<import addon="script.skinshortcuts" version="2.0.1" />
		<import addon="resource.images.studios.white" version="0.0.1" />
		<import addon="resource.images.recordlabels.white" version="0.0.1" />
	</requires>
	<extension point="xbmc.gui.skin" debugging="false">
		<res width="1920" height="1080" aspect="16:9" default="true" folder="16x9" />
	</extension>
	<extension point="xbmc.addon.metadata">
		<summary lang="en_GB">Marmalade Build - Modern orange-themed skin based on Aeon Nox</summary>
		<description lang="en_GB">A modern, easy-to-configure skin with orange accents and marmalade-inspired design. Features fully customizable home menu with widgets, live backgrounds, and multiple view types.</description>
		<platform>all</platform>
		<license>GNU GPL v2.0</license>
		<assets>
			<icon>resources/icon.png</icon>
			<fanart>resources/fanart.png</fanart>
		</assets>
	</extension>
</addon>
</addons>