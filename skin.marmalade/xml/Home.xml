<?xml version="1.0" encoding="UTF-8"?>
<window type="window" id="10000">
    <defaultcontrol always="true">9000</defaultcontrol>
    <controls>
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture>media/marmalade_bg.jpg</texture>
            <aspectratio>stretch</aspectratio>
        </control>
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>1080</height>
            <texture colordiffuse="30000000">media/glass_bg.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>
        <control type="image">
            <left>0</left><top>0</top>
            <width>420</width><height>1080</height>
            <texture colordiffuse="B0FF8C14">media/glass_menu.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>
        <control type="image">
            <left>0</left><top>0</top>
            <width>1920</width><height>80</height>
            <texture colordiffuse="C0FF8C14">media/glass_header.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>
        <control type="image">
            <left>0</left><top>80</top>
            <width>1920</width><height>4</height>
            <texture>media/orange_stripe.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>
        <control type="image">
            <left>20</left><top>15</top>
            <width>200</width><height>50</height>
            <texture>media/logo.png</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>1680</left><top>12</top>
            <width>220</width><height>35</height>
            <font>font24</font>
            <textcolor>FFF5F0E8</textcolor>
            <align>right</align>
            <label>$INFO[System.Time]</label>
        </control>
        <control type="label">
            <left>20</left><top>1035</top>
            <width>1880</width><height>30</height>
            <font>font12</font>
            <textcolor>FF807868</textcolor>
            <label>Marmalade Build  |  Free Memory: $INFO[System.FreeMemory]  |  $INFO[System.CPUTemperature]</label>
        </control>
        <control type="list" id="9000">
            <left>30</left><top>120</top>
            <width>370</width><height>900</height>
            <onleft>9000</onleft>
            <onright>9000</onright>
            <onup>9000</onup>
            <ondown>9000</ondown>
            <scrolltime tween="cubic" easing="out">300</scrolltime>
            <itemlayout height="60" width="370">
                <control type="image">
                    <left>5</left><top>4</top>
                    <width>360</width><height>52</height>
                    <texture colordiffuse="40FFFFFF">media/glass_btn.png</texture>
                </control>
                <control type="label">
                    <left>25</left><top>14</top>
                    <width>320</width><height>36</height>
                    <font>font24</font>
                    <textcolor>FFC0B8A8</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
            </itemlayout>
            <focusedlayout height="60" width="370">
                <control type="image">
                    <left>5</left><top>4</top>
                    <width>360</width><height>52</height>
                    <texture colordiffuse="CCFF8C14">media/glass_focus.png</texture>
                </control>
                <control type="label">
                    <left>25</left><top>14</top>
                    <width>320</width><height>36</height>
                    <font>font24</font>
                    <textcolor>FFFFF0D0</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
            </focusedlayout>
            <content>
                <item><label>Movies</label><onclick>ActivateWindow(Videos,MovieTitles,return)</onclick></item>
                <item><label>TV Shows</label><onclick>ActivateWindow(Videos,TvShowTitles,return)</onclick></item>
                <item><label>Add-ons</label><onclick>ActivateWindow(AddonBrowser,addons://user,return)</onclick></item>
                <item><label>Settings</label><onclick>ActivateWindow(Settings)</onclick></item>
                <item><label>Favorites</label><onclick>ActivateWindow(Favourites)</onclick></item>
                <item><label>Power</label><onclick>ActivateWindow(ShutdownMenu)</onclick></item>
            </content>
        </control>
        <control type="image">
            <left>440</left><top>120</top>
            <width>1460</width><height>880</height>
            <texture colordiffuse="40FFFFFF">media/glass_content.png</texture>
            <aspectratio>stretch</aspectratio>
        </control>
    </controls>
</window>
