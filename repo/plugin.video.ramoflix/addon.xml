<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.ramoflix" name="RamoFlix" version="1.0.4" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.resolveurl" />
        <import addon="script.module.requests" />
        <import addon="inputstream.adaptive" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">RamoFlix - Movies &amp; TV Shows</summary>
        <description lang="en_GB">Watch movies and TV shows from ramoflix.net with multiple server options and TMDB metadata.</description>
        <platform>all</platform>
    </extension>
</addon>
