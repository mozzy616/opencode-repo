<?xml version="1.0" encoding="utf-8"?>
<addon id="plugin.video.lordplayerxbox" version="1.0.0" name="LordPlayer Xbox" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
        <import addon="inputstream.adaptive"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">LordPlayer Xbox - Torrent streaming without daemon</summary>
        <description lang="en">Stream torrents on Xbox using free cloud services. No background daemon required.</description>
        <platform>all</platform>
        <assets><icon>icon.png</icon></assets>
    </extension>
</addon>
