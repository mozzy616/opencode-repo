<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.watchwrestling" name="Watch Wrestling" version="1.0.1" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" />
        <import addon="script.module.resolveurl" />
        <import addon="script.module.cloudrequest" optional="true" />
        <import addon="inputstream.adaptive" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Watch Wrestling - WWE, AEW, UFC &amp; More</summary>
        <description lang="en_GB">Stream WWE Raw, SmackDown, NXT, AEW, UFC, Boxing and more wrestling shows from watchwrestling.re</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
