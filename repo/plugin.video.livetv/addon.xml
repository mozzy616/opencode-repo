<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.livetv" name="Open TV Live" version="1.0.0" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="inputstream.adaptive"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Open TV Live - M3U IPTV Player</summary>
        <description lang="en_GB">Watch live TV channels from any M3U playlist. Configure your playlist URL in settings.</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
