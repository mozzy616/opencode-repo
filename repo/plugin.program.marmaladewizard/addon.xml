<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.program.marmaladewizard" version="1.0.0" name="Marmalade Wizard" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Marmalade Build - One Click Setup Wizard</summary>
        <description lang="en">Installs Marmalade Build skin, StreamLord, XPrime, LordPlayer, Kodi Toolbox and all dependencies in one click.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
