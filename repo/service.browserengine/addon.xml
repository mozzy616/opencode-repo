<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.browserengine" name="Browser Engine" version="1.0.0" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Browser Engine for Cloudflare bypass</summary>
        <description lang="en_GB">Runs a local FlareSolverr browser engine to bypass Cloudflare challenges and JavaScript redirects. Other addons can use this to fetch pages that require a real browser.</description>
        <platform>windows-x86_64</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
